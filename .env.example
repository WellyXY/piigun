# ─────────────────────────────────────────────
# Gateway (Railway) — 必填
# ─────────────────────────────────────────────

# Railway Redis plugin 自動注入
REDIS_URL=redis://localhost:6379/0

# Railway PostgreSQL plugin 自動注入
DATABASE_URL=postgresql://user:pass@host:5432/railway

# ─────────────────────────────────────────────
# Cloudflare R2
# ─────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=parrot-videos
# R2 bucket 的公開 URL（需在 R2 dashboard 開啟 Public Access）
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# ─────────────────────────────────────────────
# API 設定
# ─────────────────────────────────────────────
VIDEO_BASE_URL=https://your-app.railway.app/v1/jobs
WEBHOOK_SECRET=change_me_to_random_string
NUM_GPUS=1

# Cloudflare Proxy 模式（上線後開啟）
CLOUDFLARE_ENABLED=false

# Job 在 Redis 保留天數（預設 7 天，超過後從 PostgreSQL 讀取）
JOB_TTL_HOURS=168

# Job 在 queue 等待超時秒數
QUEUE_EXPIRE_SECONDS=300

# ─────────────────────────────────────────────
# Admin 後台
# ─────────────────────────────────────────────

# 管理員登入密碼（必填，請設定為強密碼）
ADMIN_PASSWORD=change-me-in-production

# ─────────────────────────────────────────────
# Credits 計費
# ─────────────────────────────────────────────

# 每秒影片消耗的 credits（預設 0.035）
CREDITS_PER_SECOND=0.035

# ─────────────────────────────────────────────
# Worker (RunPod) — 額外需要以下設定
# ─────────────────────────────────────────────

# 使用 Railway Redis 的公開 URL
# REDIS_URL=redis://your-redis.railway.app:6379

# 使用 Railway PostgreSQL 的公開 URL
# DATABASE_URL=postgresql://user:pass@your-pg.railway.app:5432/railway

# R2 (同上，worker 也需要上傳)
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=parrot-videos
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# RunPod 模型路徑
BASE_MODEL_PATH=/raid/training/ai-toolkit/models/Wan2.2-I2V-A14B-Diffusers
LORA_DIR=/raid/training/ai-toolkit/output_10s_conv
FAST_LORA_DIR=/raid/training/ai-toolkit/models/fast_loras
STORAGE_DIR=/tmp/videos
UPLOAD_DIR=/tmp/uploads

POSTPROCESS_ENABLED=true
RIFE_DIR=/raid/training/ai-toolkit/Practical-RIFE
